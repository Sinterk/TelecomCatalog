# URL del proxy-server (sin trailing slash)
VITE_PROXY_URL=http://localhost:3001

# Modo de la app:
#   office → versión de escritorio (crear cuadrantes, descargar ZIP)
#   field  → versión de terreno (seleccionar cuadrante, subir fotos)
VITE_APP_MODE=office

# Fase del módulo de anotación:
#   1 = pasivo (extrae EXIF, imagen sin modificar) — DEFAULT
#   2 = activo (overlay GPS + timestamp via Canvas API)
VITE_ANNOTATION_PHASE=1
