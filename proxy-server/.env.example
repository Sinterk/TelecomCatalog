# Puerto del servidor proxy
PORT=3001

# Origen de la PWA (CORS)
ALLOWED_ORIGIN=https://tu-dominio-pwa.com

# Opción A: Ruta al archivo JSON de la Service Account
SERVICE_ACCOUNT_KEY_FILE=./service-account.json

# Opción B: Contenido JSON completo (útil en Cloud Run / Railway / Render)
# SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# ID de la carpeta raíz en Drive (compartir con la Service Account como Editor)
# Lo encuentras en la URL de Drive: https://drive.google.com/drive/folders/ESTE_ID
DRIVE_ROOT_FOLDER_ID=1AbCdEf_XXXXXXXXXXXXXXXXXXXXXXXX
